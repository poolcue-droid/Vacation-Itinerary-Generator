-- Manali
('Snow Valley Resort', 'Manali', 5000),
('Mountain Inn', 'Manali', 2800),
('Hill View Stay', 'Manali', 2000),
('Apple Resort', 'Manali', 4500);</sql><sql name="SQL 3*">INSERT INTO activities (name, destination, cost) VALUES
